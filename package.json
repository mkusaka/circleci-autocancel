{
  "name": "circleci-autocancel",
  "version": "0.0.7-rc.0",
  "description": "Cancel redundant CircleCI workflows on the same branch (works on default branch, too).",
  "keywords": [
    "autocancel",
    "cancel",
    "ci",
    "circleci",
    "cli",
    "workflow"
  ],
  "homepage": "https://github.com/mkusaka/circleci-autocancel#readme",
  "bugs": {
    "url": "https://github.com/mkusaka/circleci-autocancel/issues"
  },
  "license": "MIT",
  "author": "Masatomo Kusaka",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkusaka/circleci-autocancel.git"
  },
  "bin": {
    "circleci-autocancel": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "test": "vitest run --coverage",
    "dev:test": "vitest",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm test",
    "prepublishOnly": "pnpm run clean && pnpm run verify && pnpm run build",
    "preversion": "pnpm run verify",
    "version": "pnpm run format && git add -A src test",
    "postversion": "git push && git push --tags",
    "release": "pnpm version",
    "release:patch": "pnpm version patch",
    "release:minor": "pnpm version minor",
    "release:major": "pnpm version major",
    "publish:dry": "pnpm publish --dry-run --no-git-checks"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.13.1"
}
